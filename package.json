{
  "name": "kiro-browser-use",
  "version": "0.1.0",
  "description": "Chrome extension that connects AI agents (like Kiro CLI) to Chrome for collaborative browsing",
  "bin": {
    "kiro-browser-use": "bridge-server/index.js"
  },
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "start": "node bridge-server/index.js",
    "bridge": "node bridge-server/server.js",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
