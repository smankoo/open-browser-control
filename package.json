{
  "name": "open-browser-control",
  "version": "0.1.0",
  "description": "Give AI agents control of your Chrome browser. Works with any MCP client.",
  "keywords": [
    "mcp",
    "browser",
    "chrome",
    "ai",
    "agent",
    "automation",
    "chrome-extension",
    "open-browser-control"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smankoo/open-browser-control"
  },
  "bin": {
    "open-browser-control": "bridge-server/index.js"
  },
  "files": [
    "bridge-server/",
    "extension/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "webpack --mode production && npm run package-extension",
    "package-extension": "rm -rf extension && cp -r dist extension",
    "dev": "webpack --mode development --watch",
    "start": "node bridge-server/index.js",
    "bridge": "node bridge-server/server.js",
    "clean": "rm -rf dist extension",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
